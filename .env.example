# === DriveWise Root Environment ===
# Copy this to .env in the project root AND in apps/api/
#
# PostgreSQL (local Docker Compose or external DB):
DATABASE_URL=postgresql://drivewise:drivewise_secret@localhost:5432/drivewise

# JWT
JWT_SECRET=change_me_to_a_long_random_secret_at_least_64_chars

# API
PORT=3000
NODE_ENV=development

# OpenStreetMap / Overpass
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# OpenRouteService (optional – leave blank to use local fallback)
OPENROUTESERVICE_API_KEY=

# OpenWeather (optional – leave blank to disable weather enrichment)
OPENWEATHER_API_KEY=

# Traffic provider: DATEX | PROMET | NONE
TRAFFIC_PROVIDER=PROMET

# Slovenian DATEX II endpoint (if TRAFFIC_PROVIDER=DATEX)
DATEX_API_URL=https://opendata.si/promet/events/

# Promet.si REST endpoint (if TRAFFIC_PROVIDER=PROMET)
PROMET_API_URL=https://promet.si/api/

# Enable background schedulers (true in production)
ENABLE_SCHEDULERS=false

# Demo / simulation mode
DEMO_MODE=true

# === Mobile App ===
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api
EXPO_PUBLIC_ENABLE_SENSOR_LAB=true
EXPO_PUBLIC_DEFAULT_SENSOR_MODE=GENERATED_SIMULATION

# === Dashboard ===
VITE_API_BASE_URL=http://localhost:3000/api
