{
  "name": "@drivewise/api",
  "version": "1.0.0",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "jest --passWithNoTests",
    "test:e2e": "bash test/run-e2e.sh",
    "test:e2e:ci": "jest --config test/jest-e2e.json --runInBand",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "ts-node src/seed/seed.ts",
    "db:generate": "prisma generate",
    "import:osm": "ts-node src/ingestion/scripts/import-osm.ts",
    "import:traffic": "ts-node src/ingestion/scripts/import-traffic.ts",
    "import:demo": "ts-node src/ingestion/scripts/import-demo.ts"
  },
  "dependencies": {
    "@drivewise/scoring": "*",
    "@drivewise/sensors": "*",
    "@drivewise/shared": "*",
    "@drivewise/simulation": "*",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/client": "^5.8.0",
    "axios": "^1.6.5",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "node-fetch": "^3.3.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/testing": "^11.1.27",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "prisma": "^5.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "@nestjs/schematics": "^11.1.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@drivewise/shared$": "<rootDir>/../../../packages/shared/src",
      "^@drivewise/scoring$": "<rootDir>/../../../packages/scoring/src",
      "^@drivewise/sensors$": "<rootDir>/../../../packages/sensors/src",
      "^@drivewise/simulation$": "<rootDir>/../../../packages/simulation/src"
    }
  }
}
