{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "baseUrl": "../..",
    "paths": {
      "@drivewise/shared": ["packages/shared/dist"],
      "@drivewise/scoring": ["packages/scoring/dist"],
      "@drivewise/sensors": ["packages/sensors/dist"],
      "@drivewise/simulation": ["packages/simulation/dist"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "test"]
}
