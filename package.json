{
  "name": "drivewise",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:dashboard\"",
    "dev:api": "npm run build:packages && npm run dev --workspace=apps/api",
    "dev:dashboard": "npm run dev --workspace=apps/dashboard",
    "dev:mobile": "npm run start --workspace=apps/mobile",
    "build:packages": "npm run build --workspace=packages/shared && npm run build --workspace=packages/scoring && npm run build --workspace=packages/sensors && npm run build --workspace=packages/simulation",
    "build": "npm run prisma:generate && npm run build:packages && npm run build --workspace=apps/api && npm run build --workspace=apps/dashboard && npm run build --workspace=apps/mobile",
    "prisma:generate": "prisma generate --schema=apps/api/prisma/schema.prisma",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run build:packages && npm run typecheck --workspaces --if-present",
    "db:migrate": "npm run db:migrate --workspace=apps/api",
    "db:seed": "npm run db:seed --workspace=apps/api",
    "import:osm": "npm run import:osm --workspace=apps/api",
    "import:traffic": "npm run import:traffic --workspace=apps/api",
    "import:demo": "npm run import:demo --workspace=apps/api"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "@xmldom/xmldom": "^0.9.10",
    "file-type": "^22.0.1",
    "form-data": "^4.0.6",
    "lodash": "^4.18.1",
    "multer": "^2.2.0",
    "postcss": "^8.5.15",
    "qs": "^6.15.2",
    "undici": "^6.27.0",
    "webpack": "^5.107.2",
    "@nestjs/swagger": {
      "js-yaml": "^4.2.0"
    },
    "@nestjs/cli": {
      "glob": "10.5.0"
    },
    "@expo/cli": {
      "glob": "10.5.0"
    },
    "@expo/config": {
      "glob": "10.5.0"
    },
    "@expo/config-plugins": {
      "glob": "10.5.0"
    },
    "tailwindcss": {
      "glob": "10.5.0"
    }
  }
}
