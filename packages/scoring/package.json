{
  "name": "@drivewise/scoring",
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@drivewise/shared": "*"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/jest": "^29.5.11",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/src/**/*.test.ts"],
    "testPathIgnorePatterns": ["/node_modules/", "/dist/"],
    "moduleNameMapper": {
      "^@drivewise/shared$": "<rootDir>/../shared/src"
    }
  }
}
